# --- Datenbank (Supabase: Settings → Database → URI) ---
# Session/Direct oft Port 5432; Pooler Port 6543 für viele kurze Verbindungen
# Sonderzeichen im Passwort (@ # ! % …) URL-encoden. Test: python scripts/test_db_connection.py
# flask db upgrade: bei Auth-Fehlern Direct-URI (Host db.<ref>.supabase.co) statt Pooler testen
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# --- Flask ---
# Wichtig: Niemals FLASK_APP=backend.app setzen (Import-Fehler). Nutze app:app oder scripts/flask_cli.sh
FLASK_APP=app:app
FLASK_ENV=development
FLASK_DEBUG=1
# Zufälliger String für Sessions (Production setzen!)
FLASK_SECRET_KEY=

# --- Clerk (Auth) ---
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
# Optional, sonst aus Publishable Key abgeleitet:
CLERK_JWKS_URL=

# --- Supabase (Storage / Admin API, nicht Auth ersetzen) ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Legacy-Alias im Code:
SUPABASE_SERVICE_ROLE=

# --- E-Mail ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
ADMIN_EMAIL=
APP_URL=https://pepeshows.de

# --- CORS (Browser-Zugriff vom Frontend) ---
# Production (z. B. Render): Vercel-URL + Custom-Domain eintragen, sonst CORS-Fehler im Browser.
# Kommaseparierte Origins. Wenn leer: app.py nutzt Fallback inkl. http://localhost:* .
# In Production: alle Frontend-Origins eintragen (Vercel, Custom-Domain). Sonst blockt der Browser (CORS).
# Für lokales Vite ggf. ergänzen:
# CORS_ORIGINS=https://pepeshows.de,https://*.vercel.app,http://localhost:5173,http://localhost:5174,http://127.0.0.1:5174
CORS_ORIGINS=

# --- Sonstiges ---
AGENCY_FEE_PERCENT=20
